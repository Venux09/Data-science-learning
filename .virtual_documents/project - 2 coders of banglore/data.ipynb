with open("initial.txt", encoding = 'utf-8') as f :
    data = f.read()
data


chunk = data.split('\n\n')#divides the data where there is some data with splits like \n\n
chunk[4]


def parse_chunk(chunk):
    chunk = chunk.strip()
    sep_chunk = chunk.split('\n')
    username = sep_chunk[0]
    no_of_posts = sep_chunk[1]
    no_of_follower = sep_chunk[2]
    no_of_following = sep_chunk[3]
    name = sep_chunk[4]
    types_of_pages = sep_chunk[5]
    bio = "n".join(sep_chunk[6:])
    # print(username,no_of_follower,no_of_following,no_of_posts,name,types_of_pages,bio,sep="\n")
    return {"username":username,"no_of_follower":no_of_follower,"no_of_following":no_of_following,"no_of_posts":no_of_posts,"name":name,"types_of_pages":types_of_pages,"bio":bio}

parse_chunk(chunk[0])
