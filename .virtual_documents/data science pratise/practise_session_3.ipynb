#subplots in the matplotlib


import matplotlib.pyplot as plt


years = list(range(2013, 2023))

messi =   [60, 58, 52, 59, 54, 51, 50, 31, 38, 35]
ronaldo = [69, 61, 57, 55, 53, 49, 44, 37, 36, 34]
neymar =  [39, 43, 39, 49, 45, 37, 34, 19, 28, 24]

matches = [50, 52, 48, 55, 53, 49, 47, 45, 44, 42]



plt.subplot(1,2,1)
plt.plot(years,messi)

plt.title('messi vs years')
plt.show()

plt.subplot(1,2,2)
plt.bar(years,messi)
plt.tight_layout()
plt.title('messi bar')
plt.show()


#taking 2*2 subplots 
plt.figure(figsize = [8,6])
plt.subplot(2,2,1)
plt.plot(years,messi,label = 'messi')
plt.title('messi vs years ')

plt.subplot(2,2,2)
plt.plot(years,ronaldo,label = 'ronaldo')
plt.title('ronaldo vs years ')

plt.subplot(2,2,3)
plt.plot(years,neymar,label = 'neymar')
plt.title('neymar vs years ')


plt.subplot(2,2,4)
plt.scatter(years,messi,label = 'messi',color='yellow')
plt.scatter(years,ronaldo,label='ronaldo',color='blue')
plt.scatter(years,neymar,label='neymar',color='red')
plt.title('footaball players vs years ')

plt.tight_layout()
plt.show()


plt.figure(figsize=[8,6])
plt.subplot(2,2)



