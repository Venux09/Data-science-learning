#in numpy loops are slow for computing it is better to use other ways like :-
#1.vectorization 






import numpy as np 
arr = np.array([1,2,3,4,5,6,7])
arr


#using the loop for printing the squares 
result = []
for _ in arr:
    result.append(_**2)
result


#using the numpy vectorization method which is more efficient 
result_numpy = arr**2
result_numpy


