#subplots help in plotting mulptiple graph in panel i think so 


import matplotlib.pyplot as plt 


x = [1,2,3,4,5,6]
y1 = [i*2 for i in x]
y2 =[i**2 for i in x]
y3 = [i**3 for i in x]



#plotting the double of X data 
plt.subplot(1,2,1)
plt.plot(x,y1)
plt.title('Double of X')
plt.xlabel('Number')
plt.ylabel('Double of the Number')
#plotting the square the X data using subplot
plt.subplot(1,2,2)
plt.plot(x,y2)
plt.title('Square of X')
plt.xlabel('Number')
plt.ylabel('square of the Number')
plt.tight_layout()
#cube of the X data using subplot for the comparism 
# plt.subplot(2,2,3)
# plt.plot(x,y3)
# plt.title('cube of X')


# More variations of x
y3 = [i ** 0.5 for i in x]
y4 = [10 - i for i in x]
plt.figure(figsize=(8, 6)) # Optional: make it bigger
plt.subplot(2, 2, 1)
plt.plot(x, y1)
plt.title('x * 2')
plt.subplot(2, 2, 2)
plt.plot(x, y2)
plt.title('x squared')
plt.subplot(2, 2, 3)
plt.plot(x, y3)
plt.title('sqrt(x)')
plt.subplot(2, 2, 4)
plt.plot(x, y4)
plt.title('10 - x')
plt.tight_layout()
plt.show()



