def Shuffle_and_split(data,test_ratio):
    np.random.seed(42)#help with the of the reproducibility for the same data in our data 
    shuffle_indices= np.random.permutation(len(data))#this returns shuffle indeces 
    test_set_size = int(len(data)*test_ratio)#this is the just size of the test data 
    test_indices = shuffle_indices[:test_set_size]#it only means it returns the indeces of the 0 to till test indeces 
    train_indices = shuffle_indices[ test_set_size:]#it returns train indeces which exclude the test indeces 
    return data.iloc[train_indices] , data.iloc[test_indices]
    
    
  


