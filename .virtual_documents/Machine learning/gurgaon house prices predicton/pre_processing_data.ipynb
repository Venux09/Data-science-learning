#doing eda here means analysiing the data 


import numpy as np


import pandas as pd


import matplotlib.pyplot as plt


df = pd.read_csv('housing.csv')


df['income_cat'] = pd.cut(df['median_income'],
bins=[0,1.5,3,4.5,6,np.inf],
labels=[1,2,3,4,5])


from sklearn.model_selection import StratifiedShuffleSplit


split = StratifiedShuffleSplit(n_splits = 1 , test_size =  0.2,random_state  = 42 )


for train_index, test_index in split.split(df, df['income_cat']):
    strat_train_set = df.loc[train_index]
    strat_test_set = df.loc[test_index]



# strat_train_set


#removing the income_Cat column from the test and train data


for sett in (strat_test_set,strat_train_set):
    sett.drop('income_cat',axis = 1,inplace = True )


df = strat_train_set.copy()


#one thing to remember is we never have to touch the data of the test set .
#we can only do our things with the data of the trainning data 


import matplotlib.pyplot as plt 
df.plot(kind  = 'scatter',x = 'latitude',y='longitude',grid = True ,cmap = "jet" ,c = 'median_house_value')
plt.show 


# df.drop(labels = 'ocean_proximity',inplace = True, axis = 1 )
df.corr()#positive correlation means they are moving in the same direction and negative correlation means they are moving in the the opposite direction 


from pandas.plotting import scatter_matrix 


attributes = ['median_house_value','median_income','housing_median_age']
scatter_matrix(df[attributes],figsize = [12,8])
plt.show()





























































































































































































