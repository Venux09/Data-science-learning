#in this file we are going to filter the data 


import pandas as pd 
df = pd.read_csv('data.csv')
df


df['Actor']#this is a way of calling a column from a data 


#this is the some methods of selection in pandas 
df[['Actor','IMDb']]#it is a way to generate multiple column thing to remember is 2 boxes 


df.loc[0]#is is the way to get the inof or everycolumns details about the index number 


df.loc[8,"Genre"]#this is a way to get the precise info about the Data in this


df.iloc[8,3]#this is a way to get the precise info about the data but in the way that columns also becomes index 


df.loc[0:2,['Actor','IMDb']]#this is method to use slicing with loc method


#in i-loc index are exclusive and in loc it is inclusive because it is desigined that way


df.loc[0,'Actor']


df.at[0,'Actor']#it is made for accessing a particular thing in the data  loc can do this thing too but at and iat is maded exclusively for this 


df.iat[0,0]


#filtering methods in pandas 


df[df['IMDb']>8]#this is the method of filtering the numbers greater or lesser


df[(df['IMDb']>6)&(df['Year']>2020)]#this is a method of filtering which is used to more than one filtering at a same time


df.query("Year>2019 and IMDb>6")#query is pandas method it is very minimal and is useful 


df2 = df[['Actor','Genre']].copy()


df2





df2


